---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import PageHero from "../components/PageHero.astro";
import PageSection from "../components/PageSection.astro";
import SectionPanel from "../components/SectionPanel.astro";
import FeatureNote from "../components/FeatureNote.astro";
import ServiceAreaList from "../components/ServiceAreaList.astro";
import { seo, serviceAreas } from "../data/site";

const surveyNotes = [
  "Pengukuran jendela di lokasi",
  "Rekomendasi model & bahan",
  "Pemasangan rapi sesuai ukuran",
];
---

<BaseLayout title={seo.area.title} description={seo.area.description}>
  <main>
    <PageHero
      layout="split"
      eyebrow="Area layanan"
      title="Jasa gorden custom untuk berbagai area di Bali."
      description="Kami melayani konsultasi, pengukuran, dan pemasangan ke lokasi customer. Jadwal survey menyesuaikan area dan kebutuhan proyek."
      waLabel="Jadwalkan pengukuran"
      waMessage="Halo, saya ingin konsultasi jadwal survey gorden di lokasi saya."
    >
      <FeatureNote
        slot="aside"
        eyebrow="Survey ke lokasi"
        description="Jika lokasi Anda belum ada di daftar, tetap bisa chat WhatsApp. Kami bantu cek jadwal dan kemungkinan survey ke area tersebut."
        items={surveyNotes}
      />
    </PageHero>

    <PageSection bg="white">
      <SectionPanel
        eyebrow="Cakupan area"
        title="Denpasar, Badung, Gianyar, Tabanan, dan sekitarnya."
        description="Area layanan menyesuaikan lokasi customer — untuk rumah, villa, kantor, hotel, dan apartemen."
        align="center"
        contentClass="mx-auto mt-10 max-w-5xl"
      >
        <ServiceAreaList areas={serviceAreas} />
      </SectionPanel>
    </PageSection>

    <CTA
      title="Ingin cek jadwal pengukuran di lokasi Anda?"
      description="Kirim lokasi, jenis ruangan, dan foto jendela lewat WhatsApp agar kami bantu atur jadwal survey."
      message="Halo, saya ingin cek jadwal pengukuran gorden di area saya."
      buttonLabel="Jadwalkan pengukuran"
    />
  </main>
</BaseLayout>
