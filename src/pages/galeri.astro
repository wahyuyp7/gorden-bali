---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import PageHero from "../components/PageHero.astro";
import PageSection from "../components/PageSection.astro";
import SectionPanel from "../components/SectionPanel.astro";
import GalleryGrid from "../components/GalleryGrid.astro";
import { gallery, seo } from "../data/site";
---

<BaseLayout title={seo.galeri.title} description={seo.galeri.description}>
  <main>
    <PageHero
      tone="dark"
      eyebrow="Galeri gorden Bali"
      title="Contoh hasil pemasangan gorden untuk berbagai ruangan."
      description="Gunakan galeri ini sebagai referensi awal. Model, warna, dan bahan tetap bisa disesuaikan dengan konsep ruangan Anda."
      waLabel="Konsultasi model & bahan"
      waMessage="Halo, saya ingin konsultasi gorden setelah melihat referensi galeri Aruma Gorden Bali."
    />

    <PageSection bg="cream">
      <SectionPanel
        eyebrow="Hasil pekerjaan"
        title="Referensi untuk rumah, villa, kantor, hotel, dan apartemen."
        description="Beberapa contoh tampilan gorden dan blind yang bisa disesuaikan dengan ukuran, warna, bahan, dan karakter ruangan."
      >
        <GalleryGrid items={gallery} />
      </SectionPanel>
    </PageSection>

    <CTA
      title="Punya referensi tampilan yang Anda suka?"
      description="Kirim foto referensi atau foto ruangan lewat WhatsApp. Kami bantu cocokkan dengan pilihan bahan dan model yang tersedia."
      message="Halo, saya ingin konsultasi gorden setelah melihat galeri Aruma Gorden Bali."
      buttonLabel="Konsultasi via WhatsApp"
    />
  </main>
</BaseLayout>
