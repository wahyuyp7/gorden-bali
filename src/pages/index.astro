---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Benefits from "../components/Benefits.astro";
import PageSection from "../components/PageSection.astro";
import SectionPanel from "../components/SectionPanel.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
import GalleryGrid from "../components/GalleryGrid.astro";
import ServiceAreaList from "../components/ServiceAreaList.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { gallery, seo, serviceAreas, services } from "../data/site";
---

<BaseLayout title={seo.home.title} description={seo.home.description}>
  <main>
    <Hero />
    <Benefits />

    <PageSection bg="cream">
      <SectionPanel
        eyebrow="Jenis layanan populer"
        title="Pilihan gorden dan blind untuk berbagai kebutuhan."
        description="Setiap produk bisa disesuaikan ukuran, warna, bahan, dan cara pemasangan."
        actionHref="/layanan"
        actionLabel="Lihat semua layanan"
      >
        <ServicesGrid items={services.slice(0, 6)} showImages />
      </SectionPanel>
    </PageSection>

    <PageSection bg="dark">
      <SectionPanel
        eyebrow="Galeri singkat"
        title="Referensi tampilan gorden untuk hunian dan properti di Bali."
        description="Contoh gaya pemasangan untuk ruang tamu, kamar, villa, kantor, dan apartemen."
        tone="dark"
        actionHref="/galeri"
        actionLabel="Lihat galeri"
        actionClass="btn-outline-light shrink-0"
      >
        <GalleryGrid items={gallery.slice(0, 6)} dark />
      </SectionPanel>
    </PageSection>

    <PageSection bg="cream-100">
      <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
        <div>
          <SectionHeader
            eyebrow="Proses pemesanan"
            title="Alur sederhana dari konsultasi sampai pemasangan."
            description="Mulai dari WhatsApp. Kirim foto ruangan agar kami bantu arahkan pilihan bahan dan model."
          />
          <WhatsAppButton variant="gold" label="Mulai konsultasi" message="Halo, saya ingin mulai konsultasi dan jadwalkan pengukuran gorden di Bali." class="mt-7" />
        </div>
        <ProcessSteps />
      </div>
    </PageSection>

    <PageSection bg="white">
      <SectionPanel
        eyebrow="Area layanan"
        title="Melayani Denpasar, Badung, Gianyar, dan area Bali lainnya."
        description="Survey dan pemasangan bisa dijadwalkan sesuai lokasi. Untuk area di luar daftar, chat kami untuk cek jadwal terdekat."
        align="center"
        contentClass="mx-auto mt-10 max-w-5xl"
      >
        <ServiceAreaList areas={serviceAreas.slice(0, 10)} />
        <div class="mt-8 text-center">
          <a href="/area-layanan" class="btn-outline">Lihat semua area layanan</a>
        </div>
      </SectionPanel>
    </PageSection>

    <FAQ />
    <CTA />
  </main>
</BaseLayout>
