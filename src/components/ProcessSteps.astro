---
import { processSteps } from "../data/site";
---

<ol class="grid gap-5 sm:grid-cols-2">
  {
    processSteps.map((step, index) => (
      <li class="soft-card p-7">
        <div class="flex items-center gap-3">
          <span class="step-badge">{String(index + 1).padStart(2, "0")}</span>
          <span class="text-[11px] font-bold uppercase tracking-editorial text-gold">Langkah {index + 1}</span>
        </div>
        <h3 class="card-title mt-5">{step.title}</h3>
        <p class="mt-3 text-[15px] leading-relaxed text-charcoal">{step.description}</p>
      </li>
    ))
  }
</ol>
