---
import { processSteps } from "../data/site";
---

<ol class="grid gap-4 sm:grid-cols-2">
  {
    processSteps.map((step, index) => (
      <li class="soft-card p-6">
        <div class="flex items-center gap-3">
          <span class="step-badge">{index + 1}</span>
          <span class="text-xs font-bold uppercase tracking-[0.16em] text-warm-700">Langkah {index + 1}</span>
        </div>
        <h3 class="mt-4 text-lg font-bold leading-snug">{step.title}</h3>
        <p class="mt-3 text-[15px] leading-relaxed text-neutral-600">{step.description}</p>
      </li>
    ))
  }
</ol>
