---
import { whatsappLink } from "../data/site";

const { items = [], class: className = "" } = Astro.props;
---

<div class:list={["flex flex-wrap gap-2", className]}>
  {
    items.map((item) => (
      <a
        href={whatsappLink(item.message)}
        class="trust-pill text-[12px] uppercase tracking-[0.06em] transition hover:border-gold/50"
        target="_blank"
        rel="noopener noreferrer"
      >
        {item.label}
      </a>
    ))
  }
</div>
