---
import WhatsAppButton from "./WhatsAppButton.astro";
import { footerDescription, footerServices, navItems, site, whatsappLink } from "../data/site";

const linkClass =
  "inline-block py-1.5 text-[15px] leading-relaxed text-charcoal transition hover:text-onyx focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold";
const headingClass = "text-[11px] font-bold uppercase tracking-editorial text-gold";
---

<footer class="border-t border-border-soft/40 bg-sand pb-24 pt-14 sm:pb-14">
  <div class="container-site">
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4 lg:gap-10">
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-3" aria-label={`${site.name} - halaman utama`}>
          <img
            src="/images/logo.png"
            alt={site.name}
            class="h-10 w-10 shrink-0 object-contain"
            width="40"
            height="40"
            loading="lazy"
          />
          <span class="font-display text-lg font-bold text-onyx">{site.name}</span>
        </a>
        <p class="mt-5 max-w-sm text-[15px] leading-relaxed text-charcoal">
          {footerDescription}
        </p>
        <WhatsAppButton variant="gold" class="mt-6" label="Chat WhatsApp" />
      </div>

      <nav aria-label="Navigasi footer">
        <p class={headingClass}>Halaman</p>
        <ul class="mt-5 space-y-1">
          {
            navItems.map((item) => (
              <li>
                <a href={item.href} class={linkClass}>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav aria-label="Layanan gorden">
        <p class={headingClass}>Layanan</p>
        <ul class="mt-5 space-y-1">
          {
            footerServices.map((service) => (
              <li>
                <a href="/layanan" class={linkClass}>
                  {service}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div>
        <p class={headingClass}>Kontak</p>
        <ul class="mt-5 space-y-4 text-[15px] leading-relaxed text-charcoal">
          <li>
            <span class="block text-[11px] font-bold uppercase tracking-[0.12em] text-onyx">WhatsApp</span>
            <a
              href={whatsappLink()}
              class="mt-1 inline-block font-semibold text-whatsapp transition hover:text-[#1fb855] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-whatsapp"
              target="_blank"
              rel="noopener noreferrer"
            >
              {site.phoneDisplay}
            </a>
          </li>
          <li>
            <span class="block text-[11px] font-bold uppercase tracking-[0.12em] text-onyx">Jam operasional</span>
            <span class="mt-1 block">{site.hours}</span>
          </li>
          <li>
            <span class="block text-[11px] font-bold uppercase tracking-[0.12em] text-onyx">Instagram</span>
            <a
              href={site.instagramUrl}
              class="mt-1 inline-block font-semibold text-onyx transition hover:text-gold focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold"
              target="_blank"
              rel="noopener noreferrer"
            >
              {site.instagram}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-border-soft/50 pt-8">
      <p class="text-center text-xs leading-relaxed text-charcoal/70 sm:text-left">
        &copy; {new Date().getFullYear()} {site.name}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
