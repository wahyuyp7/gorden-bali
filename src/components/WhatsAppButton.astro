---
import { whatsappLink } from "../data/site";

const {
  label = "Konsultasi via WhatsApp",
  message,
  variant = "primary",
  class: className = "",
} = Astro.props;

const href = whatsappLink(message);
const classes = variant === "light" ? "btn-wa-light" : "btn-wa";
---

<a href={href} class={`${classes} ${className}`} target="_blank" rel="noopener noreferrer">
  <svg class="h-5 w-5 shrink-0" viewBox="0 0 32 32" aria-hidden="true">
    <path
      fill="currentColor"
      d="M16.02 3.2A12.74 12.74 0 0 0 3.29 15.93c0 2.24.58 4.42 1.69 6.35L3.2 28.8l6.67-1.75a12.69 12.69 0 0 0 6.15 1.57h.01A12.74 12.74 0 0 0 28.8 15.9 12.75 12.75 0 0 0 16.02 3.2Zm.01 23.27h-.01c-1.96 0-3.88-.53-5.56-1.52l-.4-.24-3.95 1.04 1.05-3.85-.26-.4a10.53 10.53 0 0 1-1.61-5.57 10.73 10.73 0 1 1 10.74 10.54Zm5.88-8.03c-.32-.16-1.9-.94-2.2-1.05-.3-.11-.52-.16-.74.16-.22.32-.85 1.05-1.04 1.27-.19.22-.38.24-.7.08-.32-.16-1.36-.5-2.59-1.59-.96-.85-1.61-1.91-1.8-2.23-.19-.32-.02-.5.14-.66.14-.14.32-.38.48-.57.16-.19.22-.32.32-.54.11-.22.05-.4-.03-.57-.08-.16-.74-1.78-1.01-2.44-.27-.64-.54-.55-.74-.56l-.63-.01c-.22 0-.57.08-.87.4-.3.32-1.14 1.11-1.14 2.71 0 1.59 1.17 3.14 1.33 3.35.16.22 2.3 3.51 5.57 4.92.78.34 1.38.54 1.86.69.78.25 1.49.21 2.05.13.62-.09 1.9-.78 2.17-1.53.27-.75.27-1.39.19-1.53-.08-.14-.3-.22-.62-.38Z"
    />
  </svg>
  {label}
</a>
