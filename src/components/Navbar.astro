---
import WhatsAppButton from "./WhatsAppButton.astro";
import { navItems, site } from "../data/site";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header id="top" class="sticky top-0 z-50 border-b border-border-soft/40 bg-white/95 backdrop-blur-md">
  <nav class="container-site flex h-[4.75rem] items-center justify-between gap-6">
    <a href="/" class="flex min-w-0 items-center gap-3" aria-label={`${site.name} - halaman utama`}>
      <img src="/images/logo.png" alt={site.name} class="h-10 w-10 shrink-0 object-contain sm:h-11 sm:w-11" width="44" height="44" />
      <span class="truncate font-display text-lg font-bold leading-tight tracking-tight text-onyx sm:text-xl">{site.name}</span>
    </a>

    <div class="hidden items-center gap-1 lg:flex">
      {
        navItems.map((item) => {
          const itemPath = item.href.replace(/\/$/, "") || "/";
          const isActive = currentPath === itemPath;

          return (
            <a href={item.href} class="nav-link" aria-current={isActive ? "page" : undefined}>
              {item.label}
            </a>
          );
        })
      }
    </div>

    <div class="hidden items-center lg:flex">
      <WhatsAppButton label="Konsultasi" variant="gold" class="min-h-11 px-5" />
    </div>

    <button
      id="menu-toggle"
      class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-sm border border-border-soft/60 text-onyx lg:hidden"
      type="button"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Buka menu"
    >
      <span class="flex flex-col gap-1.5" aria-hidden="true">
        <span class="block h-px w-5 bg-current"></span>
        <span class="block h-px w-5 bg-current"></span>
        <span class="block h-px w-5 bg-current"></span>
      </span>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-border-soft/40 bg-white lg:hidden">
    <div class="container-site flex flex-col gap-1 py-5">
      {
        navItems.map((item) => {
          const itemPath = item.href.replace(/\/$/, "") || "/";
          const isActive = currentPath === itemPath;

          return (
            <a
              href={item.href}
              class:list={[
                "mobile-menu-link rounded-sm px-3 py-3.5 text-sm font-semibold uppercase tracking-[0.08em]",
                isActive ? "bg-sand text-onyx" : "text-charcoal hover:bg-sand",
              ]}
              aria-current={isActive ? "page" : undefined}
            >
              {item.label}
            </a>
          );
        })
      }
      <WhatsAppButton variant="gold" class="mt-3 min-h-11 w-full" />
    </div>
  </div>
</header>

<script>
  const toggle = document.querySelector("#menu-toggle");
  const menu = document.querySelector("#mobile-menu");
  const links = document.querySelectorAll(".mobile-menu-link");

  toggle?.addEventListener("click", () => {
    const isOpen = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!isOpen));
    toggle.setAttribute("aria-label", isOpen ? "Buka menu" : "Tutup menu");
    menu?.classList.toggle("hidden", isOpen);
  });

  links.forEach((link) => {
    link.addEventListener("click", () => {
      toggle?.setAttribute("aria-expanded", "false");
      menu?.classList.add("hidden");
    });
  });
</script>
