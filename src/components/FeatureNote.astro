---
const {
  eyebrow,
  description,
  items = [],
  class: className = "",
} = Astro.props;
---

<div class:list={["soft-card p-6 md:p-7", className]}>
  {eyebrow && <p class="text-[11px] font-bold uppercase tracking-editorial text-gold">{eyebrow}</p>}
  {description && <p class="mt-4 text-[15px] leading-relaxed text-charcoal">{description}</p>}
  {
    items.length > 0 && (
      <ul class="mt-5 space-y-3 text-sm text-charcoal">
        {items.map((item) => (
          <li class="flex items-start gap-3">
            <span class="check-icon" aria-hidden="true">
              <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M2 6l3 3 5-5" />
              </svg>
            </span>
            {item}
          </li>
        ))}
      </ul>
    )
  }
  <slot />
</div>
