---
const {
  eyebrow,
  description,
  items = [],
  class: className = "",
} = Astro.props;
---

<div class:list={["soft-card p-6", className]}>
  {eyebrow && <p class="text-xs font-bold uppercase tracking-[0.16em] text-warm-700">{eyebrow}</p>}
  {description && <p class="mt-3 text-[15px] leading-relaxed text-neutral-600">{description}</p>}
  {
    items.length > 0 && (
      <ul class="mt-4 space-y-2 text-sm text-neutral-600">
        {items.map((item) => (
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-whatsapp" aria-hidden="true"></span>
            {item}
          </li>
        ))}
      </ul>
    )
  }
  <slot />
</div>
