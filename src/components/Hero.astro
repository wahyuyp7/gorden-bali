---
import WhatsAppButton from "./WhatsAppButton.astro";
import ResponsiveImage from "./ResponsiveImage.astro";
import { site } from "../data/site";

const trustBadges = ["Survey ke Lokasi", "Custom Ukuran", "Pemasangan Rapi", "Melayani Bali"];
---

<section class="relative min-h-[calc(100svh-4.75rem)] overflow-hidden">
  <div class="absolute inset-0">
    <ResponsiveImage
      src="/images/hero-gorden.png"
      alt="Interior rumah dengan gorden custom elegan di Bali"
      class="h-full w-full object-cover"
      width="1920"
      height="1080"
      loading="eager"
      decoding="async"
      fetchpriority="high"
      sizes="100vw"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-onyx/85 via-onyx/70 to-onyx/40" aria-hidden="true"></div>
  </div>

  <div class="container-site relative flex min-h-[calc(100svh-4.75rem)] items-center py-16 md:py-20">
    <div class="max-w-2xl">
      <p class="mb-4 text-[11px] font-bold uppercase tracking-editorial text-gold">Jasa gorden custom di Bali</p>
      <h1 class="font-display text-4xl font-bold leading-[1.08] tracking-tight text-white sm:text-5xl lg:text-[3.5rem]">
        Gorden Custom untuk Rumah, Villa & Properti di Bali
      </h1>
      <p class="mt-6 max-w-xl text-base leading-relaxed text-white/80 md:text-lg">
        Konsultasi, ukur, buat, dan pasang gorden sesuai kebutuhan ruangan — dari rumah hingga hotel dan apartemen.
      </p>

      <div class="mt-10 flex flex-col gap-3 sm:flex-row sm:items-center">
        <WhatsAppButton
          label="Konsultasi via WhatsApp"
          variant="gold"
          message="Halo, saya ingin konsultasi gorden custom di Bali untuk rumah/villa/kantor."
        />
        <a href="/galeri" class="btn-outline-light">Lihat hasil kerja</a>
      </div>

      <ul class="mt-12 flex flex-wrap gap-x-8 gap-y-3">
        {
          trustBadges.map((badge) => (
            <li class="flex items-center gap-2 text-sm font-medium text-white/90">
              <span class="check-icon" aria-hidden="true">
                <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M2 6l3 3 5-5" />
                </svg>
              </span>
              {badge}
            </li>
          ))
        }
      </ul>

      <p class="mt-8 text-sm text-white/60">{site.hours}</p>
    </div>
  </div>
</section>
