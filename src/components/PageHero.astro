---
import WhatsAppButton from "./WhatsAppButton.astro";

const {
  eyebrow,
  title,
  description,
  tone = "light",
  layout = "narrow",
  waLabel,
  waMessage,
  class: className = "",
} = Astro.props;

const isDark = tone === "dark";
const isSplit = layout === "split";
const showWa = Boolean(waLabel || waMessage);
---

<section
  class:list={[
    isDark ? "bg-warm-900 text-white" : "border-b border-stone-200/70 bg-gradient-to-b from-cream-100 to-cream-50",
    "py-12 md:py-16",
    className,
  ]}
>
  <div class:list={["container-site", !isSplit && "max-w-4xl"]}>
    {
      isSplit ? (
        <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
          <div>
            {eyebrow && <p class={isDark ? "mb-3 text-xs font-bold uppercase tracking-[0.18em] text-cream-200" : "eyebrow"}>{eyebrow}</p>}
            <h1 class:list={["page-title", isDark && "text-white"]}>{title}</h1>
            {description && <p class:list={["page-lead", isDark && "max-w-none text-cream-100/90"]}>{description}</p>}
            {showWa && <WhatsAppButton label={waLabel ?? "Konsultasi via WhatsApp"} message={waMessage} class="mt-8" />}
            <slot name="actions" />
          </div>
          <div>
            <slot name="aside" />
          </div>
        </div>
      ) : (
        <>
          {eyebrow && <p class={isDark ? "mb-3 text-xs font-bold uppercase tracking-[0.18em] text-cream-200" : "eyebrow"}>{eyebrow}</p>}
          <h1 class:list={["page-title", isDark && "text-white"]}>{title}</h1>
          {description && <p class:list={["page-lead", isDark && "text-cream-100/90"]}>{description}</p>}
          {showWa && <WhatsAppButton label={waLabel ?? "Konsultasi via WhatsApp"} message={waMessage} class="mt-8" />}
          <slot name="actions" />
        </>
      )
    }
    <slot />
  </div>
</section>
