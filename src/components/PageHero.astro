---
import WhatsAppButton from "./WhatsAppButton.astro";

const {
  eyebrow,
  title,
  description,
  tone = "light",
  layout = "narrow",
  waLabel,
  waMessage,
  class: className = "",
} = Astro.props;

const isDark = tone === "dark";
const isSplit = layout === "split";
const showWa = Boolean(waLabel || waMessage);
---

<section
  class:list={[
    isDark ? "bg-onyx text-white" : "border-b border-border-soft/30 bg-sand",
    "py-14 md:py-20 lg:py-24",
    className,
  ]}
>
  <div class:list={["container-site", !isSplit && "max-w-4xl"]}>
    {
      isSplit ? (
        <div class="grid gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
          <div>
            {eyebrow && (
              <p class={isDark ? "mb-4 text-[11px] font-bold uppercase tracking-editorial text-gold" : "eyebrow"}>
                {eyebrow}
              </p>
            )}
            <h1 class:list={["page-title", isDark && "text-white"]}>{title}</h1>
            {description && <p class:list={["page-lead", isDark && "max-w-none text-white/75"]}>{description}</p>}
            {showWa && (
              <WhatsAppButton label={waLabel ?? "Konsultasi via WhatsApp"} message={waMessage} variant="gold" class="mt-8" />
            )}
            <slot name="actions" />
          </div>
          <div>
            <slot name="aside" />
          </div>
        </div>
      ) : (
        <>
          {eyebrow && (
            <p class={isDark ? "mb-4 text-[11px] font-bold uppercase tracking-editorial text-gold" : "eyebrow"}>
              {eyebrow}
            </p>
          )}
          <h1 class:list={["page-title", isDark && "text-white"]}>{title}</h1>
          {description && <p class:list={["page-lead", isDark && "text-white/75"]}>{description}</p>}
          {showWa && (
            <WhatsAppButton label={waLabel ?? "Konsultasi via WhatsApp"} message={waMessage} variant="gold" class="mt-8" />
          )}
          <slot name="actions" />
        </>
      )
    }
    <slot />
  </div>
</section>
