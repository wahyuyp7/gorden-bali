---
import ResponsiveImage from "./ResponsiveImage.astro";
import { services, whatsappLink } from "../data/site";

const {
  items = services,
  showImages = false,
  showCta = false,
} = Astro.props;
---

<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
  {
    items.map((service) => (
      <article class="soft-card group flex min-h-52 flex-col overflow-hidden">
        {showImages && (
          <div class="overflow-hidden">
            <ResponsiveImage
              src={service.image}
              alt={`Contoh ${service.title.toLowerCase()} di Bali`}
              class="aspect-[4/3] w-full object-cover transition duration-500 group-hover:scale-[1.02]"
              width="720"
              height="540"
              loading="lazy"
              decoding="async"
              sizes="(min-width: 1024px) 30vw, (min-width: 640px) 45vw, calc(100vw - 2.5rem)"
            />
          </div>
        )}
        <div class="flex flex-1 flex-col p-6 md:p-7">
          <h3 class="card-title">{service.title}</h3>
          <p class="mt-3 flex-1 text-[15px] leading-relaxed text-charcoal">{service.description}</p>
          {showCta && service.ctaLabel && service.ctaMessage && (
            <a
              href={whatsappLink(service.ctaMessage)}
              class="mt-5 inline-flex min-h-10 items-center gap-1 text-xs font-bold uppercase tracking-[0.1em] text-onyx transition hover:text-gold focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-gold"
              target="_blank"
              rel="noopener noreferrer"
            >
              {service.ctaLabel}
              <span aria-hidden="true">→</span>
            </a>
          )}
        </div>
      </article>
    ))
  }
</div>
