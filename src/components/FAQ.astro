---
import PageSection from "./PageSection.astro";
import SectionHeader from "./SectionHeader.astro";
import WhatsAppButton from "./WhatsAppButton.astro";
import { faqs } from "../data/site";

const { items = faqs } = Astro.props;
---

<PageSection bg="sand">
  <SectionHeader
    eyebrow="FAQ"
    title="Pertanyaan yang sering ditanyakan."
    description="Jawaban singkat sebelum Anda lanjut konsultasi via WhatsApp."
    align="center"
  />

  <div class="mx-auto mt-12 max-w-3xl overflow-hidden border border-border-soft/60 bg-white">
    {
      items.map((faq, index) => (
        <details class:list={["group p-6", index > 0 && "border-t border-border-soft/50"]}>
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-left text-[15px] font-bold text-onyx md:text-base">
            {faq.question}
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-sm bg-sand text-lg leading-none text-onyx transition group-open:rotate-45">
              +
            </span>
          </summary>
          <p class="mt-4 text-[15px] leading-relaxed text-charcoal">{faq.answer}</p>
        </details>
      ))
    }
  </div>

  <div class="mt-10 text-center">
    <WhatsAppButton variant="gold" label="Tanya langsung" message="Halo, saya punya pertanyaan tentang jasa gorden custom di Bali." />
  </div>
</PageSection>
