---
import PageSection from "./PageSection.astro";
import SectionHeader from "./SectionHeader.astro";
import { benefits } from "../data/site";
---

<PageSection bg="white" border>
  <SectionHeader
    eyebrow="Keunggulan layanan"
    title="Dibuat sesuai ukuran, gaya, dan kebutuhan ruangan Anda."
    description="Dari rekomendasi bahan sampai pemasangan — hasil akhir rapi dan nyaman dipakai setiap hari."
    align="center"
  />

  <div class="mx-auto mt-12 grid max-w-6xl gap-5 sm:grid-cols-2 lg:grid-cols-4">
    {
      benefits.map((item) => (
        <article class="soft-card p-7">
          <span class="check-icon" aria-hidden="true">
            <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M2 6l3 3 5-5" />
            </svg>
          </span>
          <h3 class="card-title mt-5">{item.title}</h3>
          <p class="mt-3 text-[15px] leading-relaxed text-charcoal">{item.description}</p>
        </article>
      ))
    }
  </div>
</PageSection>
