---
import PageSection from "./PageSection.astro";
import WhatsAppButton from "./WhatsAppButton.astro";

const {
  eyebrow = "Siap dibantu?",
  title = "Butuh gorden untuk rumah, villa, kantor, hotel, atau apartemen?",
  description = "Kirim foto ruangan via WhatsApp. Kami bantu rekomendasi model, bahan, dan jadwal pengukuran.",
  message = "Halo, saya ingin konsultasi kebutuhan gorden dan jadwal pengukuran di Bali.",
  buttonLabel = "Konsultasi via WhatsApp",
} = Astro.props;
---

<PageSection bg="onyx" class="!py-0">
  <div class="py-16 text-center md:py-24">
    <p class="mb-4 text-[11px] font-bold uppercase tracking-editorial text-gold">{eyebrow}</p>
    <h2 class="mx-auto max-w-3xl font-display text-3xl font-bold leading-tight tracking-tight text-white md:text-4xl lg:text-[2.75rem]">
      {title}
    </h2>
    <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-white/70 md:text-lg">
      {description}
    </p>
    <WhatsAppButton label={buttonLabel} message={message} variant="gold" class="mt-10" />
  </div>
</PageSection>
