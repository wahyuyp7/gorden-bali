---
import PageSection from "./PageSection.astro";
import WhatsAppButton from "./WhatsAppButton.astro";

const {
  eyebrow = "Siap dibantu?",
  title = "Butuh gorden untuk rumah, villa, kantor, hotel, atau apartemen?",
  description = "Kirim foto ruangan via WhatsApp. Kami bantu rekomendasi model, bahan, dan jadwal pengukuran.",
  message = "Halo, saya ingin konsultasi kebutuhan gorden dan jadwal pengukuran di Bali.",
  buttonLabel = "Konsultasi via WhatsApp",
} = Astro.props;
---

<PageSection bg="cream">
  <div class="rounded-2xl bg-warm-900 px-6 py-12 text-center text-white shadow-soft ring-1 ring-warm-700/30 md:px-12 md:py-16">
    <p class="mb-3 text-xs font-bold uppercase tracking-[0.18em] text-cream-200">{eyebrow}</p>
    <h2 class="mx-auto max-w-3xl font-serif text-3xl font-bold leading-tight text-white md:text-4xl">
      {title}
    </h2>
    <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-cream-100/90 md:text-lg">
      {description}
    </p>
    <WhatsAppButton label={buttonLabel} message={message} class="mt-8" />
  </div>
</PageSection>
