---
const {
  eyebrow,
  title,
  description,
  align = "left",
  tone = "light",
} = Astro.props;

const isCenter = align === "center";
const isDark = tone === "dark";
---

<div class={`${isCenter ? "mx-auto text-center" : ""} max-w-2xl`}>
  {eyebrow && <p class={isDark ? "mb-3 text-xs font-bold uppercase tracking-[0.18em] text-cream-200" : "eyebrow"}>{eyebrow}</p>}
  <h2 class={isDark ? "font-serif text-3xl font-bold leading-tight text-white md:text-4xl" : "section-title"}>{title}</h2>
  {description && <p class={`${isCenter ? "mx-auto" : ""} ${isDark ? "mt-4 max-w-2xl text-base leading-relaxed text-white/70 md:text-lg" : "section-lead"}`}>{description}</p>}
</div>
