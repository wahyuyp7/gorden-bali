---
const {
  eyebrow,
  title,
  description,
  align = "left",
  tone = "light",
} = Astro.props;

const isCenter = align === "center";
const isDark = tone === "dark";
---

<div class={`${isCenter ? "mx-auto text-center" : ""} max-w-2xl`}>
  {
    eyebrow && (
      <p class={isDark ? "mb-4 text-[11px] font-bold uppercase tracking-editorial text-gold" : "eyebrow"}>
        {eyebrow}
      </p>
    )
  }
  <h2
    class={
      isDark
        ? "font-display text-3xl font-bold leading-tight tracking-tight text-white md:text-4xl"
        : "section-title"
    }
  >
    {title}
  </h2>
  {
    description && (
      <p
        class={`${isCenter ? "mx-auto" : ""} ${isDark ? "mt-5 max-w-2xl text-base leading-relaxed text-white/70 md:text-lg" : "section-lead"}`}
      >
        {description}
      </p>
    )
  }
</div>
